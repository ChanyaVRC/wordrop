{
  "name": "wordrop",
  "version": "1.0.0",
  "description": "Wordrop — 好きな単語で出題し、URL共有で遊べる単語当てゲーム（答えはサーバー保持で覗き見不可）",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev -- vite",
    "dev:build": "vite build && wrangler pages dev",
    "build": "vite build",
    "check": "tsc -p tsconfig.json && tsc -p functions/tsconfig.json",
    "deploy": "vite build && wrangler pages deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^3.78.0"
  }
}
